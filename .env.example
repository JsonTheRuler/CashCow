# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# Optional: Alpha Vantage (if you switch data_vendors to alpha_vantage)
ALPHA_VANTAGE_API_KEY=

# Optional: Alpaca paper/live execution from the web app (see webapp)
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
# Use https://paper-api.alpaca.markets for paper (default in app)
# ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Optional: Tradier brokerage (execution_mode=tradier in web UI)
TRADIER_ACCESS_TOKEN=
TRADIER_ACCOUNT_ID=

# Optional: custom broker bridge — POST JSON {ticker, rating, side, order_qty, ts, execution_mode}
EXECUTION_WEBHOOK_URL=
# Optional shared secret (sent as X-TradingAgents-Secret)
EXECUTION_WEBHOOK_SECRET=

# Cash Cow Alpha Signal (divergence copy-trade framing — educational only)
# CASH_COW_ALPHA_DIVERGENCE_MIN=5.0
# X handle without @ — default follows "No Limits" (@NoLimits)
# CASH_COW_X_SCREEN_NAME=NoLimits
# CASH_COW_X_DISPLAY_NAME=No Limits
# Or set a full follow URL:
# CASH_COW_X_FOLLOW_URL=https://x.com/intent/follow?screen_name=NoLimits

# Dashboard → API (copy-click tracking + alpha-signals)
# CASH_COW_API_URL=http://127.0.0.1:8090

# React Hub (Streamlit Hub tab embeds this URL in an iframe)
# CASH_COW_HUB_URL=http://127.0.0.1:3000
# CASH_COW_HUB_IFRAME_HEIGHT=800
